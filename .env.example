# ─── SERVER ───
PORT=3000

# ─── DATABASE ───
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/citadel?retryWrites=true&w=majority

# ─── SECURITY ───
JWT_SECRET=your_random_secret_key_here

# ─── FRONTEND URL (your Netlify URL - required for CORS) ───
FRONTEND_URL=https://your-site.netlify.app

# ─── CLOUDINARY (image uploads) ───
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# ─── SMTP (contact form emails via Brevo) ───
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_smtp_user
SMTP_PASS=your_brevo_smtp_password

# ─── EMAIL ───
EMAIL_FROM=citadeloftruthmercyassembly@gmail.com
EMAIL_FROM_NAME=Citadel of Truth
ADMIN_NOTIFY_EMAIL=david07israel@gmail.com
